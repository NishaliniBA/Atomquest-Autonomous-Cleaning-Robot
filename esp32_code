#include <Arduino.h>
#include "driver/ledc.h" // IDF LEDC driver

/* ----------------- CONFIG (tweak these) ----------------- */

// Obstacle detection thresholds
const unsigned long OBSTACLE_THRESHOLD_CM = 30; // general threshold
const unsigned long CRITICAL_REVERSE_CM = 10; // 0..10 cm -> special handling

// Timings for the critical sequence
const unsigned long CRITICAL_STOP_MS_PRE = 2000; // stop for 2.0 s before reversing
const unsigned long REVERSE_MS = 1500; // reverse for 1.5 s
const unsigned long CRITICAL_STOP_MS_POST = 1000; // stop for 1.0 s after reversing

// New IR sensor timings
const unsigned long IR_STOP_MS = 1000; // stop and wait 1s on IR detection
const unsigned long IR_REVERSE_MS = 1500; // reverse for 1.5s after IR detection (changed)

// Servo pulse calibration (tweak to reach mechanical ends safely)
const float SERVO_MIN_PULSE_MS = 0.5f;
const float SERVO_MAX_PULSE_MS = 2.5f;

// Servo timing & motion
const unsigned long SERVO_MOVE_SETTLE_MS = 400;
const unsigned long SERVO_HOLD_MS = 1000; // hold while scanning

// Behavior timings
const unsigned long CENTER_IGNORE_AFTER_DETECT_MS = 2000;
const unsigned long PIVOT_TURN_MS = 1000;

/* ----------------- PINOUT ----------------- */

const int TRIG_PIN = 18;
const int ECHO_PIN = 19;
const int SERVO_PIN = 21;

const int ENA = 25, IN1 = 26, IN2 = 33;
const int ENB = 27, IN3 = 14, IN4 = 32;

// IR sensors (active-low detection)
const int IR_LEFT_PIN = 34;
const int IR_RIGHT_PIN = 35;

// Vacuum BLDC signal pin (to ESC / BLDC signal input)
const int VAC_SIGNAL_PIN = 23;

/* ----------------- LEDC/IDF CONFIG ----------------- */

const ledc_timer_t SERVO_TIMER = LEDC_TIMER_0;
const ledc_mode_t SERVO_MODE = LEDC_HIGH_SPEED_MODE;
const uint32_t SERVO_FREQ_HZ = 50; // 50Hz for servo-style ESC pulses
const uint8_t SERVO_TIMER_BITS = 13; // servo resolution (13-bit)
const ledc_channel_t SERVO_CHANNEL = LEDC_CHANNEL_0;

const ledc_timer_t MOTOR_TIMER = LEDC_TIMER_1;
const ledc_mode_t MOTOR_MODE = LEDC_LOW_SPEED_MODE;
const uint32_t MOTOR_FREQ_HZ = 2000;
const uint8_t MOTOR_TIMER_BITS = 8;
const ledc_channel_t MOTOR_A_CHANNEL = LEDC_CHANNEL_1;
const ledc_channel_t MOTOR_B_CHANNEL = LEDC_CHANNEL_2;

// VAC uses servo timer (50 Hz) and a dedicated channel
const ledc_channel_t VAC_CHANNEL = LEDC_CHANNEL_3;
// Vacuum pulse values (servo-style). Start conservative.
const float VAC_FULL_PULSE_MS = 1.95f; // adjust up to ~2.0ms if needed
const float VAC_STOP_PULSE_MS = 1.00f; // 1 ms = idle/stop for most ESCs

/* ----------------- FORWARD/SCAN ANGLES ----------------- */

const int SERVO_CENTER_ANGLE = 90;
const int SERVO_RIGHT_ANGLE = 0; // full right
const int SERVO_LEFT_ANGLE = 180; // full left

/* ----------------- SPEED TUNING ----------------- */

const uint8_t DEFAULT_MOTOR_SPEED = 255; // drive speed (0-255)
const uint8_t PIVOT_MOTOR_SPEED = 255; // pivot speed

/* ----------------- FORWARD DECLARATIONS ----------------- */

void setupLEDC();
uint32_t servoAngleToDuty(int angle);
uint32_t pulseMsToDutyFloat(float pulseMs);
void ledcWriteDuty(ledc_mode_t mode, ledc_channel_t channel, uint32_t duty);
void setServoAngle(int angle);
unsigned long readUltrasonicCM();
unsigned long scanSide(int angle);

void forwardMove(uint8_t speed = DEFAULT_MOTOR_SPEED);
void stopMove();
void reverseMove(uint8_t speed = DEFAULT_MOTOR_SPEED);
void pivotLeft(uint8_t speed = PIVOT_MOTOR_SPEED);
void pivotRight(uint8_t speed = PIVOT_MOTOR_SPEED);

// vacuum control
void setVacuum(bool on);

/* ----------------- SETUP / LOOP ----------------- */

void setup() {
  Serial.begin(115200);

  // pins: ultrasonic, motors, servo
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  pinMode(ENA, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);

  pinMode(ENB, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  // IR sensors: many modules pull LOW when detecting
  pinMode(IR_LEFT_PIN, INPUT_PULLUP);
  pinMode(IR_RIGHT_PIN, INPUT_PULLUP);

  //Vacuum signal pin will be driven by LEDC; ensure it set as output
  pinMode(VAC_SIGNAL_PIN, OUTPUT);

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);

  setupLEDC();

  // Servo to center
  setServoAngle(SERVO_CENTER_ANGLE);
  delay(500);

  // Arming: ensure ESC sees STOP pulse for a short time at boot
  setVacuum(false);
  delay(1000); // keep STOP pulse for 1 second to allow ESC arming

  // start forward and vacuum
  forwardMove();
  setVacuum(true);

  Serial.println("Setup complete - moving forward with vacuum ON");
}

void loop() {
  // Highest priority: IR sensors immediate response (active-low: LOW means detection)
  bool irLeftDetected = (digitalRead(IR_LEFT_PIN) == LOW);
  bool irRightDetected = (digitalRead(IR_RIGHT_PIN) == LOW);

  if (irLeftDetected || irRightDetected) {
    Serial.printf("IR detection! left=%d right=%d -> IMMEDIATE stop\n", irLeftDetected, irRightDetected);
    stopMove();
    setVacuum(false); // vacuum off when bot stops
    delay(IR_STOP_MS); // wait 1s

    Serial.println("IR triggered reverse for 1.5s");
    reverseMove();
    setVacuum(true); // vacuum ON during reverse
    delay(IR_REVERSE_MS); // reverse for 1.5s

    stopMove();
    setVacuum(false);
    delay(150);

    forwardMove();
    setVacuum(true);
    Serial.println("Resuming forward after IR handling");

    // short settle to avoid immediate re-trigger
    delay(100);
    return; // skip ultrasonic processing this cycle
  }

  // Ensure servo centered before measuring (ultrasonic-based logic)
  setServoAngle(SERVO_CENTER_ANGLE);
  delay(SERVO_MOVE_SETTLE_MS);

  unsigned long centerDist = readUltrasonicCM();
  Serial.printf("Center distance: %lu cm\n", centerDist);

  if (centerDist > 0 && centerDist <= OBSTACLE_THRESHOLD_CM) {
    // Critical very-close case: stop 2s, reverse 1.5s, stop 1s, then scan & turn
    if (centerDist <= CRITICAL_REVERSE_CM) {
      Serial.println("CRITICAL: obstacle within 0-10 cm.");
      Serial.println("Stopping for 2.0 s before reversing.");
      stopMove();
      setVacuum(false);
      delay(CRITICAL_STOP_MS_PRE);

      Serial.println("Reversing both wheels for 1.5 s.");
      reverseMove(); // reverse at default speed
      setVacuum(true);
      delay(REVERSE_MS);

      Serial.println("Stopping for 1.0 s after reverse.");
      stopMove();
      setVacuum(false);
      delay(CRITICAL_STOP_MS_POST);

      Serial.println("Rescanning sides after reverse.");
      // proceed to scan and pivot below
    } else {
      // Non-critical close obstacle: stop briefly then scan/turn
      Serial.println("Obstacle detected ahead (11-25 cm). Stopping briefly.");
      stopMove();
      setVacuum(false);
      delay(CENTER_IGNORE_AFTER_DETECT_MS); // idle a bit
    }

    // Scan sides and decide
    unsigned long rightDist = scanSide(SERVO_RIGHT_ANGLE);
    unsigned long leftDist = scanSide(SERVO_LEFT_ANGLE);
    Serial.printf("Scan distances => Right: %lu cm, Left: %lu cm\n", rightDist, leftDist);

    bool preferRight = (rightDist >= leftDist);

    // Return servo to center then pivot
    setServoAngle(SERVO_CENTER_ANGLE);
    delay(SERVO_MOVE_SETTLE_MS);

    if (preferRight) {
      Serial.println("Pivoting RIGHT");
      pivotRight();
    } else {
      Serial.println("Pivoting LEFT");
      pivotLeft();
    }

    // During pivot vacuum remains ON
    setVacuum(true);
    delay(PIVOT_TURN_MS);

    stopMove();
    setVacuum(false);
    delay(150);

    forwardMove();
    setVacuum(true);
    Serial.println("Resuming forward");
  }

  delay(50);
}

/* ----------------- MOVEMENT PRIMITIVES (fixed directions) ----------------- */

// Forward uses left forward (IN1 HIGH, IN2 LOW) and right forward inverted (IN3 LOW, IN4 HIGH)
void forwardMove(uint8_t speed) {
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);

  ledcWriteDuty(MOTOR_MODE, MOTOR_A_CHANNEL, speed);
  ledcWriteDuty(MOTOR_MODE, MOTOR_B_CHANNEL, speed);
}

void stopMove() {
  ledcWriteDuty(MOTOR_MODE, MOTOR_A_CHANNEL, 0);
  ledcWriteDuty(MOTOR_MODE, MOTOR_B_CHANNEL, 0);
  digitalWrite(IN1, LOW); digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW); digitalWrite(IN4, LOW);
}

// Reverse both wheels: invert directions from forward
void reverseMove(uint8_t speed) {
  // Left wheel reverse: IN1 LOW, IN2 HIGH
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);

  // Right wheel reverse: reverse of forward (forward is IN3 LOW, IN4 HIGH) -> reverse is IN3 HIGH, IN4 LOW
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);

  ledcWriteDuty(MOTOR_MODE, MOTOR_A_CHANNEL, speed);
  ledcWriteDuty(MOTOR_MODE, MOTOR_B_CHANNEL, speed);
}

void pivotRight(uint8_t speed) {
  // Pivot right: left forward, right backward
  digitalWrite(IN1, HIGH); digitalWrite(IN2, LOW); // left forward
  digitalWrite(IN3, HIGH); digitalWrite(IN4, LOW); // right backward

  ledcWriteDuty(MOTOR_MODE, MOTOR_A_CHANNEL, speed);
  ledcWriteDuty(MOTOR_MODE, MOTOR_B_CHANNEL, speed);
}

void pivotLeft(uint8_t speed) {
  // Pivot left: left backward, right forward
  digitalWrite(IN1, LOW); digitalWrite(IN2, HIGH); // left backward
  digitalWrite(IN3, LOW); digitalWrite(IN4, HIGH); // right forward

  ledcWriteDuty(MOTOR_MODE, MOTOR_A_CHANNEL, speed);
  ledcWriteDuty(MOTOR_MODE, MOTOR_B_CHANNEL, speed);
}

/* ----------------- VACUUM CONTROL (servo-style PWM on 50 Hz) ----------------- */

// Convert pulse width (ms) to duty for SERVO timer/resolution
uint32_t pulseMsToDutyFloat(float pulseMs) {
  float periodMs = 1000.0f / (float)SERVO_FREQ_HZ; // 20 ms
  float fraction = pulseMs / periodMs;
  uint32_t maxDuty = (1u << SERVO_TIMER_BITS) - 1u;
  return (uint32_t)(fraction * (float)maxDuty + 0.5f);
}

void setVacuum(bool on) {
  if (on) {
    uint32_t duty = pulseMsToDutyFloat(VAC_FULL_PULSE_MS);
    ledcWriteDuty(SERVO_MODE, VAC_CHANNEL, duty);
  } else {
    uint32_t duty = pulseMsToDutyFloat(VAC_STOP_PULSE_MS);
    ledcWriteDuty(SERVO_MODE, VAC_CHANNEL, duty);
  }
}

/* ----------------- SERVO / LEDC helpers (IDF) ----------------- */

uint32_t servoAngleToDuty(int angle) {
  if (angle < 0) angle = 0;
  if (angle > 180) angle = 180;
  float pulseMs = SERVO_MIN_PULSE_MS + ((float)angle / 180.0f) * (SERVO_MAX_PULSE_MS - SERVO_MIN_PULSE_MS);
  float periodMs = 1000.0f / (float)SERVO_FREQ_HZ;
  float fraction = pulseMs / periodMs;
  uint32_t maxDuty = (1u << SERVO_TIMER_BITS) - 1u;
  return (uint32_t)(fraction * (float)maxDuty + 0.5f);
}

void setServoAngle(int angle) {
  uint32_t duty = servoAngleToDuty(angle);
  ledcWriteDuty(SERVO_MODE, SERVO_CHANNEL, duty);
}

/* lightweight wrapper for IDF duty API */
void ledcWriteDuty(ledc_mode_t mode, ledc_channel_t channel, uint32_t duty) {
  ledc_set_duty(mode, channel, duty);
  ledc_update_duty(mode, channel);
}

/* ----------------- ULTRASONIC ----------------- */

unsigned long readUltrasonicCM() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  unsigned long duration = pulseIn(ECHO_PIN, HIGH, 38000UL);
  if (duration == 0) return 0;
  return duration / 58; // approx cm
}

unsigned long scanSide(int angle) {
  setServoAngle(angle);
  delay(SERVO_MOVE_SETTLE_MS);
  delay(SERVO_HOLD_MS);
  unsigned long d = readUltrasonicCM();
  delay(50);
  return d;
}

/* ----------------- LEDC setup (robust, error-checked) ----------------- */

void setupLEDC() {
  // allow core to finish init on some boards/cores
  delay(100);
  esp_err_t err;
  ledc_timer_config_t timer_conf;
  ledc_channel_config_t ch_conf;

  // --- Servo timer config (13-bit) ---
  memset(&timer_conf, 0, sizeof(timer_conf));
  timer_conf.speed_mode = SERVO_MODE;
  timer_conf.duty_resolution = (ledc_timer_bit_t)LEDC_TIMER_13_BIT;
  timer_conf.timer_num = SERVO_TIMER;
  timer_conf.freq_hz = SERVO_FREQ_HZ;
  timer_conf.clk_cfg = LEDC_AUTO_CLK;
  err = ledc_timer_config(&timer_conf);
  if (err != ESP_OK) {
    Serial.printf("ledc_timer_config servo failed: 0x%X\n", err);
    delay(50);
    err = ledc_timer_config(&timer_conf);
    Serial.printf("ledc_timer_config servo retry: 0x%X\n", err);
  }

  // --- Servo channel config ---
  memset(&ch_conf, 0, sizeof(ch_conf));
  ch_conf.gpio_num = SERVO_PIN;
  ch_conf.speed_mode = SERVO_MODE;
  ch_conf.channel = SERVO_CHANNEL;
  ch_conf.intr_type = LEDC_INTR_DISABLE;
  ch_conf.timer_sel = SERVO_TIMER;
  ch_conf.duty = 0;
  ch_conf.hpoint = 0;
  err = ledc_channel_config(&ch_conf);
  if (err != ESP_OK) {
    Serial.printf("ledc_channel_config servo failed: 0x%X\n", err);
    delay(50);
    err = ledc_channel_config(&ch_conf);
    Serial.printf("ledc_channel_config servo retry: 0x%X\n", err);
  }

  // --- Vacuum (BLDC ESC) channel on servo timer ---
  memset(&ch_conf, 0, sizeof(ch_conf));
  ch_conf.gpio_num = VAC_SIGNAL_PIN;
  ch_conf.speed_mode = SERVO_MODE;      // use servo (50 Hz) timer
  ch_conf.channel = VAC_CHANNEL;
  ch_conf.intr_type = LEDC_INTR_DISABLE;
  ch_conf.timer_sel = SERVO_TIMER;      // IMPORTANT: use SERVO_TIMER (50 Hz)
  ch_conf.duty = 0;
  ch_conf.hpoint = 0;
  err = ledc_channel_config(&ch_conf);
  if (err != ESP_OK) {
    Serial.printf("ledc_channel_config vac failed: 0x%X\n", err);
    delay(50);
    err = ledc_channel_config(&ch_conf);
    Serial.printf("ledc_channel_config vac retry: 0x%X\n", err);
  }

  // --- Motor timer config (8-bit) ---
  memset(&timer_conf, 0, sizeof(timer_conf));
  timer_conf.speed_mode = MOTOR_MODE;
  timer_conf.duty_resolution = (ledc_timer_bit_t)LEDC_TIMER_8_BIT;
  timer_conf.timer_num = MOTOR_TIMER;
  timer_conf.freq_hz = MOTOR_FREQ_HZ;
  timer_conf.clk_cfg = LEDC_AUTO_CLK;
  err = ledc_timer_config(&timer_conf);
  if (err != ESP_OK) {
    Serial.printf("ledc_timer_config motor failed: 0x%X\n", err);
    delay(50);
    err = ledc_timer_config(&timer_conf);
    Serial.printf("ledc_timer_config motor retry: 0x%X\n", err);
  }

  // --- Motor A channel ---
  memset(&ch_conf, 0, sizeof(ch_conf));
  ch_conf.gpio_num = ENA;
  ch_conf.speed_mode = MOTOR_MODE;
  ch_conf.channel = MOTOR_A_CHANNEL;
  ch_conf.intr_type = LEDC_INTR_DISABLE;
  ch_conf.timer_sel = MOTOR_TIMER;
  ch_conf.duty = 0;
  ch_conf.hpoint = 0;
  err = ledc_channel_config(&ch_conf);
  if (err != ESP_OK) {
    Serial.printf("ledc_channel_config motA failed: 0x%X\n", err);
    delay(50);
    err = ledc_channel_config(&ch_conf);
    Serial.printf("ledc_channel_config motA retry: 0x%X\n", err);
  }

  // --- Motor B channel ---
  memset(&ch_conf, 0, sizeof(ch_conf));
  ch_conf.gpio_num = ENB;
  ch_conf.speed_mode = MOTOR_MODE;
  ch_conf.channel = MOTOR_B_CHANNEL;
  ch_conf.intr_type = LEDC_INTR_DISABLE;
  ch_conf.timer_sel = MOTOR_TIMER;
  ch_conf.duty = 0;
  ch_conf.hpoint = 0;
  err = ledc_channel_config(&ch_conf);
  if (err != ESP_OK) {
    Serial.printf("ledc_channel_config motB failed: 0x%X\n", err);
    delay(50);
    err = ledc_channel_config(&ch_conf);
    Serial.printf("ledc_channel_config motB retry: 0x%X\n", err);
  }

  // Install fade service (optional). Ignore "already installed" error.
  err = ledc_fade_func_install(0);
  if (err != ESP_OK && err != ESP_ERR_INVALID_STATE) {
    Serial.printf("ledc_fade_func_install returned: 0x%X\n", err);
  }

  Serial.println("LEDC setup completed (checked errors)");
}
